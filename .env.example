NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trading_bot?schema=public"

# Symbols: use dynamic list from Binance Futures (400-500) or static list
USE_DYNAMIC_SYMBOLS=true
SYMBOL_LIMIT=500
# Only used when USE_DYNAMIC_SYMBOLS=false
SYMBOLS=BTCUSDT,ETHUSDT

# Binance futures interval for strategy
INTERVAL=1h

# Strategy: volume > SPIKE_MULTIPLIER x average of last VOLUME_WINDOW hours
VOLUME_WINDOW=20
SPIKE_MULTIPLIER=6
BUY_NOTIONAL_USD=100
TP1_PCT=9
TP1_SELL_PCT=35
TP2_PCT=25
TP2_SELL_PCT=35
FORCE_EXIT_HOURS=24

# cron-job.org token for header X-CRON-TOKEN
CRON_TOKEN=change-me
