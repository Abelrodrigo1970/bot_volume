generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SignalSide {
  LONG
  NO_SIGNAL
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum ExitReason {
  TP1
  TP2
  TIME_EXIT
}

model Signal {
  id             String     @id @default(cuid())
  createdAt      DateTime   @default(now())
  symbol         String
  side           SignalSide
  interval       String
  spikeRatio     Float
  currentVolume  Float
  averageVolume  Float
  candleOpen     Float
  candleClose    Float
  reason         String
  trade          Trade?
}

model Trade {
  id                   String      @id @default(cuid())
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  signalId             String?     @unique
  signal               Signal?     @relation(fields: [signalId], references: [id])
  symbol               String
  status               TradeStatus @default(OPEN)
  entryPrice           Float
  quantity             Float
  remainingQty         Float
  notionalUsd          Float
  openedAt             DateTime
  closedAt             DateTime?
  realizedPnlUsd       Float       @default(0)
  tp1ExecutedAt        DateTime?
  tp2ExecutedAt        DateTime?
  timeExitExecuted     Boolean     @default(false)
  binanceOrderFilled   Boolean     @default(true)
  exits                TradeExit[]
}

model TradeExit {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  tradeId      String
  trade        Trade      @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  reason       ExitReason
  price        Float
  quantity     Float
  pnlUsd       Float
  gainPct      Float
  executedAt   DateTime
}

model JobRun {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  finishedAt    DateTime?
  source        String
  success       Boolean  @default(false)
  symbols       String
  openedTrades  Int      @default(0)
  exitsCount    Int      @default(0)
  signalsCount  Int      @default(0)
  error         String?
}
